# ─────────────────────────────────────────────────────────────
#  機密 / 憑證 —— 絕對不進版控（首要防線）
# ─────────────────────────────────────────────────────────────
# 環境變數與設定
.env
.env.*
*.env
!.env.example
config.local.*
secrets.*
**/secret*.yaml
**/secret*.yml

# 金鑰 / 憑證 / 簽章
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
id_rsa*
id_ed25519*
*.kubeconfig
kubeconfig*
cosign.key
*.htpasswd
*-signature.secret

# 雲端 / 服務憑證
*credentials*.json
*service-account*.json
.aws/
.gcp/

# ─────────────────────────────────────────────────────────────
#  資料檔 —— ETL 產物與原始資料不進版控（體積大、非程式碼）
# ─────────────────────────────────────────────────────────────
*.parquet
*.csv
!webapp/data/gantry_groups_frontend.json   # 前端用的公開門架對照（無個資）
*.tar.gz
*.tgz
*.zip
*.db
*.sqlite*
staging/
raw/
dataset/
*.jsonl                                     # Spark 批次的斷點續跑 state

# ─────────────────────────────────────────────────────────────
#  執行期產物 / 暫存 / log
# ─────────────────────────────────────────────────────────────
logs/
*.log
*.out
*.bak
*.bak-*
.tmp_convert/
tmp/

# ─────────────────────────────────────────────────────────────
#  Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────
#  Node（若前端日後導入建置工具）
# ─────────────────────────────────────────────────────────────
node_modules/
dist/
.cache/

# ─────────────────────────────────────────────────────────────
#  編輯器 / 作業系統
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
